# generate the first 24 numbers of the fibonacci sequence
<decoder>
  <set var="last" value="1"/>
  <set var="v1" value="0"/>
  <loop var="v0" end="24">
    <sample/>
    <set var="tmp" value="{$v1}"/>
    <set var="v1" value="{$last + $v1}"/>
    <set var="last" value="{$tmp}"/>
  </loop>
</decoder>

